{
  "title": "Windows-like JIS (Ctrl toggle Kana/Eisu, Fn=Cmd, F11/F12, Cmd+D, Cmd+Tab)",
  "rules": [
    {
      "description": "Caps Lock (black-dot up-arrow key) -> Left Command (adds extra Command)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "caps_cmd_held",
                "value": 1
              }
            },
            {
              "key_code": "left_command"
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "caps_cmd_held",
                "value": 0
              }
            }
          ]
        }
      ]
    },
    {
      "description": "CapsLock+{C,V,X,Z,A,S} -> Cmd shortcuts (copy/paste/cut/undo/selectall/save)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "c", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "c", "modifiers": [ "command" ] } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "v", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "v", "modifiers": [ "command" ] } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "x", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "x", "modifiers": [ "command" ] } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "z", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "z", "modifiers": [ "command" ] } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "a", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "a", "modifiers": [ "command" ] } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "s", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "s", "modifiers": [ "command" ] } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "tab", "modifiers": { "optional": [ "any" ] } },
          "conditions": [ { "type": "variable_if", "name": "caps_cmd_held", "value": 1 } ],
          "to": [ { "key_code": "tab", "modifiers": [ "command" ] } ]
        }
      ]
    },
    {
      "description": "Shift+Cmd+S -> Screenshot selection to clipboard (Ctrl+Cmd+Shift+4)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "s",
            "modifiers": {
              "mandatory": [
                "command",
                "shift"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "4",
              "modifiers": [
                "control",
                "command",
                "shift"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Control alone toggles input source (direct en<->ja) while keeping Control when held",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "ja"
              }
            }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                {
                  "language": "en"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "en"
              }
            }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                {
                  "language": "ja"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_control"
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "ja"
              }
            }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                {
                  "language": "en"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_control"
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "language": "en"
              }
            }
          ],
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                {
                  "language": "ja"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "F11/F12 -> Home/End (+Shift selects)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "f11",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "home"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f12",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "end"
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f11",
            "modifiers": {
              "mandatory": [
                "shift"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": [
                "command",
                "shift"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "f12",
            "modifiers": {
              "mandatory": [
                "shift"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": [
                "command",
                "shift"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Cmd+D -> Show Desktop (Win+D)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "d",
            "modifiers": {
              "mandatory": [
                "command"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "apple_vendor_keyboard_key_code": "expose_desktop"
            }
          ]
        }
      ]
    }
  ]
}